# LLM Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here
TOGETHER_AI_API_KEY=your_together_ai_api_key_here

# Local LLM Providers (Ollama / LM Studio) — optional, defaults to localhost
OLLAMA_BASE_URL=http://127.0.0.1:11434
LMSTUDIO_BASE_URL=http://localhost:1234/v1
# LM Studio 에서 API 키 인증을 켠 경우 설정 (비우면 'lmstudio' 더미 키 사용)
LMSTUDIO_API_KEY=

# PDF Parser Settings (optional)
PDF_PARSER_PORT=5001
PDF_PARSER_TIMEOUT=10000000

# Debug Settings (optional)
AI_SDK_LOG_WARNINGS=false

# Public Mode Settings
NEXT_PUBLIC_PUBLIC_MODE=false
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Official Demo Settings (enables legal pages and footer links)
NEXT_PUBLIC_HERIPO_OFFICIAL_DEMO=false

# Data Retention Settings (days before automatic deletion, official demo only)
NEXT_PUBLIC_DATA_RETENTION_DAYS=7

# Rate Limiting (server-side only)
TOTP_SECRET=
DAILY_LIMIT=3
OTP_MAX_ATTEMPTS=3
CONCURRENT_TASK_LIMIT=1

# Webhook Settings (Public Mode only)
WEBHOOK_URL=
WEBHOOK_SECRET=

# Sample Task Settings
NEXT_PUBLIC_ALLOW_SAMPLE_DELETION=false

# Turnstile Settings (Cloudflare CAPTCHA, Public Mode only)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Chunked Upload Settings (required for large file uploads >= 50MB)
UPLOAD_SESSION_SECRET=
